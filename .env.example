PORT=3000
NODE_ENV=development

# PostgreSQL database connection URL (for production)
DATABASE_URL="postgresql://username:password@localhost:5432/robustotp?schema=public"

# Brevo API — get from https://app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=

# Verified sender in Brevo Dashboard → Senders
EMAIL_FROM=

# Keep-Alive emails (comma-separated, to keep Brevo API active)
KEEP_ALIVE_EMAILS=

# Cron authorization token
CRON_SECRET=

# SMTP configuration for free direct delivery fallback (e.g., smtp.gmail.com)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
